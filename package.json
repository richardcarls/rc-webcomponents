{
  "private": true,
  "name": "@rcarls/workspace-root",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardcarls/rc-webcomponents.git"
  },
  "homepage": "https://github.com/richardcarls/rc-webcomponents#readme",
  "description": "A collection of themeable headless web components architected for progressive enhancement and accessibility.",
  "author": "Richard Carls <richard.j.carls@gmail.com>",
  "license": "MIT",
  "packageManager": "yarn@4.16.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "yarn workspaces foreach --all --parallel --topological --exclude '@rcarls/docs' run build",
    "test": "yarn workspaces foreach --all --exclude '@rcarls/docs' run test:browser",
    "cem:analyze": "cem analyze",
    "docs": "yarn cem:analyze && yarn workspace @rcarls/docs run dev",
    "docs:build": "yarn cem:analyze && yarn workspace @rcarls/docs run build",
    "yalc:publish": "yarn workspaces foreach --all --topological --exclude '@rcarls/docs' run yalc:publish",
    "version:packages": "changeset version",
    "release": "yarn build && changeset publish",
    "prepare": "husky"
  },
  "customElements": "dist/custom-elements.json",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@guanghechen/rollup-plugin-copy": "^6.0.9",
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "4.1.5",
    "@yarnpkg/types": "^4.0.1",
    "api-viewer-element": "^1.0.0-pre.10",
    "axe-core": "^4.11.4",
    "husky": "^9.1.7",
    "lit": "^3.0.0",
    "playwright": "^1.56.0",
    "rollup": "^4.60.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.6",
    "vitest-browser-lit": "^1.0.1"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "dependenciesMeta": {
    "vitest-browser-lit": {
      "unplugged": true
    }
  }
}
