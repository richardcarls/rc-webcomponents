    "access": "public"
  },
  "version": "0.1.0",
  "description": "Adapter factories for lezer, unified, and shiki tokenizers for rc-textarea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardcarls/rc-webcomponents.git",
    "directory": "packages/rc-textarea-adapters"
  },
