{
  "name": "@rcarls/rc-search-bar",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.1",
  "description": "Search field wrapper for a native <input type=\"search\"> with icon chrome, clear button, and debounced events.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardcarls/rc-webcomponents.git",
    "directory": "packages/rc-search-bar"
  },
  "homepage": "https://richardcarls.github.io/rc-webcomponents/components/rc-search-bar",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/rc-search-bar.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/packages/rc-search-bar/src/index.d.ts",
        "default": "./dist/rc-search-bar.js"
      }
    },
    "./define": {
      "import": {
        "types": "./dist/types/packages/rc-search-bar/src/define.d.ts",
        "default": "./dist/rc-search-bar-define.js"
      }
    }
  },
  "types": "./dist/types/packages/rc-search-bar/src/index.d.ts",
  "sideEffects": [
    "./dist/rc-search-bar-define.js"
  ],
  "customElements": "dist/custom-elements.json",
  "scripts": {
    "build": "tsc && vite build && cem analyze",
    "cem:analyze": "cem analyze",
    "preview": "vite preview",
    "test:browser": "vitest --run",
    "test:browser:chrome": "vitest --run --project=chromium",
    "test:browser:firefox": "vitest --run --project=firefox"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@vitest/browser-playwright": "4.1.5",
    "lit": "^3.0.0",
    "playwright": "^1.56.0",
    "rollup": "^4.60.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.6",
    "vitest-browser-lit": "^1.0.1"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "dependencies": {
    "@rcarls/rc-common": "workspace:*"
  }
}
