{
  "name": "@rcarls/rc-common",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.1",
  "description": "Shared controllers, directives, and DOM utilities for rc-webcomponents.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardcarls/rc-webcomponents.git",
    "directory": "packages/rc-common"
  },
  "homepage": "https://richardcarls.github.io/rc-webcomponents/",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/rc-common.umd.cjs",
  "module": "./dist/rc-common.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/rc-common.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/rc-common.umd.cjs"
      }
    }
  },
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:browser": "vitest --run",
    "test:browser:chrome": "vitest --run --project=chromium",
    "test:browser:firefox": "vitest --run --project=firefox"
  },
  "dependencies": {
    "@oddbird/css-anchor-positioning": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "4.1.5",
    "lit": "^3.0.0",
    "playwright": "^1.56.0",
    "rollup": "^4.60.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.6",
    "vitest-browser-lit": "^1.0.1"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  }
}
