{
  "name": "@rcarls/rc-range-slider",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Headless WAI-ARIA range slider web component built with Lit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardcarls/rc-webcomponents.git",
    "directory": "packages/rc-range-slider"
  },
  "homepage": "https://github.com/richardcarls/rc-webcomponents#readme",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/rc-range-slider.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/packages/rc-range-slider/src/index.d.ts",
        "default": "./dist/rc-range-slider.js"
      }
    },
    "./define": {
      "import": {
        "types": "./dist/types/packages/rc-range-slider/src/define.d.ts",
        "default": "./dist/rc-range-slider-define.js"
      }
    }
  },
  "types": "./dist/types/packages/rc-range-slider/src/index.d.ts",
  "sideEffects": [
    "./dist/rc-range-slider-define.js"
  ],
  "customElements": "dist/custom-elements.json",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cem analyze",
    "cem:analyze": "cem analyze",
    "preview": "vite preview",
    "test:browser": "vitest",
    "test:browser:chrome": "vitest --project=chromium",
    "test:browser:firefox": "vitest --project=firefox",
    "yalc:publish": "yalc publish --push"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@guanghechen/rollup-plugin-copy": "^6.0.9",
    "@vitest/browser-playwright": "4.1.5",
    "lit": "^3.0.0",
    "playwright": "^1.56.0",
    "rollup": "^4.60.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.6",
    "vitest-browser-lit": "^1.0.1"
  },
  "dependencies": {
    "@rcarls/rc-common": "workspace:^"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  }
}
